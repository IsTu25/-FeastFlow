{
  "title": "FeastFlow \u2014 Command Center",
  "style": "dark",
  "refresh": "2s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "schemaVersion": 38,
  "uid": "feastflow-resilience-cmd",
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Core System Resilience",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "stat",
      "id": 101,
      "title": "System Success Rate",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "order_success_rate_percentage",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 85
              },
              {
                "color": "green",
                "value": 98
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 102,
      "title": "Avg API Latency (ms)",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "gateway_response_time_seconds_sum * 1000 / gateway_response_time_seconds_count",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 103,
      "title": "Internal Microservice Health",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(up{job=~\".*\"}) / count(up{job=~\".*\"}) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 100
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 104,
      "title": "Current Chaos Injected",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "kitchen_chaos_delay_ms",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "id": 200,
      "title": "Observability Traces & SLOs",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "id": 201,
      "title": "P95 Latency by Service",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (internal_service_latency_seconds_bucket))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 202,
      "title": "Request Throughput (Orders/min)",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(orders_total[2m])) * 60",
          "legendFormat": "Global Orders/min",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 20,
            "showPoints": "always"
          }
        }
      }
    },
    {
      "type": "row",
      "id": 300,
      "title": "Resilience Failure Analysis",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "bargauge",
      "id": 301,
      "title": "Failure Reason Distribution",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (reason) (order_failures_total)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "vertical",
        "displayMode": "gradient",
        "reduceOptions": {
          "values": true,
          "limit": 10
        }
      }
    },
    {
      "type": "state-timeline",
      "id": 302,
      "title": "Circuit Breaker Status History",
      "gridPos": {
        "x": 8,
        "y": 17,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "expr": "circuit_breaker_state",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OPTIMAL (Closed)",
                  "color": "green"
                },
                "1": {
                  "text": "OPEN (Redirecting)",
                  "color": "red"
                },
                "2": {
                  "text": "HALF-OPEN",
                  "color": "orange"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "row",
      "id": 400,
      "title": "Real-time Distributed Logs (Loki)",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "logs",
      "id": 401,
      "title": "FeastFlow Service Logs",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "expr": "{container=~\".*\"} | json",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}
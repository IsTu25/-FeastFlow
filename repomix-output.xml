name: 🚀 FeastFlow Cloud Deployment

on:
  push:
    branches: [ main, master ]
  pull_request:
    branches: [ main, master ]

jobs:
  build-and-test:
    name: 🏗️ Build & Verify Services
    runs-on: ubuntu-latest
    
    steps:
      - name: ⬇️ Checkout Repository
        uses: actions/checkout@v4

      - name: 🛠️ Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: 🏗️ Build All Microservices (Cacheable)
        run: |
          docker compose build --parallel --no-cache

      - name: 🧪 Unit Test Validation
        run: |
          # Example for one service (you can add others)
          docker compose run --rm stock-service npm test

  push-to-registry:
    name: 📤 Push to GitHub Container Registry
    needs: build-and-test
    if: github.event_name == 'push'
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write

    steps:
      - name: ⬇️ Checkout Repository
        uses: actions/checkout@v4

      - name: 🔐 Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: 🏷️ Build & Push (Stock Service)
        uses: docker/build-push-action@v5
        with:
          context: ./stock-service
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/stock-service:latest

      - name: 🏷️ Build & Push (Order Gateway)
        uses: docker/build-push-action@v5
        with:
          context: ./order-gateway
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/order-gateway:latest

      - name: 🏷️ Build & Push (Kitchen Queue)
        uses: docker/build-push-action@v5
        with:
          context: ./kitchen-queue
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/kitchen-queue:latest

  # 🚀 AUTOMATIC DEPLOYMENT (OPTIONAL)

<file path="deploy/docker-compose.prod.yml">
services:
  # In Prod, we might use a Managed Redis (AWS ElastiCache), 
  # but Docker is fine for high-performance demos.
  redis:
    image: redis:7-alpine
    restart: always
    command: redis-server --appendonly yes --maxmemory 512mb --maxmemory-policy allkeys-lru
    ports:
      - "6379:6379"

  postgres:
    image: postgres:15-alpine
    restart: always
    environment:
      POSTGRES_USER: ${DB_USER:-iut_user}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-iut_password}
      POSTGRES_DB: iut_cafeteria
    volumes:
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql
      - pgdata:/var/lib/postgresql/data
    ports:
      - "5432:5432"

  identity-provider:
    image: ghcr.io/${GH_USER:-istu25}/identity-provider:latest
    restart: always
    environment:
      - PORT=3000
      - DB_URL=postgresql://${DB_USER:-iut_user}:${DB_PASSWORD:-iut_password}@postgres:5432/iut_cafeteria
      - JWT_SECRET=${JWT_SECRET:-super_secret_jwt_key}
      - REDIS_URL=redis://redis:6379
      - SERVICE_NAME=identity-provider
      - OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
    depends_on:
      - postgres
      - redis

  stock-service:
    image: ghcr.io/${GH_USER:-istu25}/stock-service:latest
    restart: always
    environment:
      - PORT=3000
      - DB_URL=postgresql://${DB_USER:-iut_user}:${DB_PASSWORD:-iut_password}@postgres:5432/iut_cafeteria
      - REDIS_URL=redis://redis:6379
      - SERVICE_NAME=stock-service
      - OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
    depends_on:
      - postgres
      - redis

  order-gateway:
    image: ghcr.io/${GH_USER:-istu25}/order-gateway:latest
    restart: always
    environment:
      - PORT=3000
      - JWT_SECRET=${JWT_SECRET:-super_secret_jwt_key}
      - REDIS_URL=redis://redis:6379
      - STOCK_SERVICE_URL=http://stock-service:3000
      - KITCHEN_QUEUE_URL=http://kitchen-queue:3000
      - NOTIFICATION_HUB_URL=http://notification-hub:3000
      - SERVICE_NAME=order-gateway
      - DB_URL=postgresql://${DB_USER:-iut_user}:${DB_PASSWORD:-iut_password}@postgres:5432/iut_cafeteria
      - OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
    depends_on:
      - stock-service
      - kitchen-queue
      - redis

  kitchen-queue:
    image: ghcr.io/${GH_USER:-istu25}/kitchen-queue:latest
    restart: always
    environment:
      - PORT=3000
      - REDIS_URL=redis://redis:6379
      - NOTIFICATION_HUB_URL=http://notification-hub:3000
      - SERVICE_NAME=kitchen-queue
      - OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
    depends_on:
      - redis
      - notification-hub

  notification-hub:
    image: ghcr.io/${GH_USER:-istu25}/notification-hub:latest
    restart: always
    environment:
      - PORT=3000
      - REDIS_URL=redis://redis:6379
      - SERVICE_NAME=notification-hub
      - OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
    depends_on:
      - redis

  nginx:
    image: nginx:alpine
    restart: always
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
    ports:
      - "80:80"
      - "443:443"
    depends_on:
      - order-gateway
      - identity-provider

  # OBSERVABILITY STACK (High Memory Usage - Optional for low-tier VPS)
  prometheus:
    image: prom/prometheus:latest
    restart: always
    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml
    ports:
      - "9090:9090"

  grafana:
    image: grafana/grafana:latest
    restart: always
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_PASSWORD:-admin}
    volumes:
      - ./grafana/provisioning:/etc/grafana/provisioning
    ports:
      - "3006:3000"

  jaeger:
    image: jaegertracing/all-in-one:latest
    restart: always
    ports:
      - "16686:16686"
      - "4317:4317"

volumes:
  pgdata:
  redisdata:
</file>


<file path="react-dashboard/src/index.css">
/* ─── Reset & Base ──────────────────────────────────────────────────────────── */
*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

:root {
    --bg-dark: #020617;
    --bg-surface: rgba(15, 23, 42, 0.6);
    --bg-card: rgba(30, 41, 59, 0.4);
    --border-light: rgba(148, 163, 184, 0.1);
    --border-glow: rgba(56, 189, 248, 0.2);

    /* Accents */
    --accent-emerald: #10b981;
    --accent-cyan: #06b6d4;
    --accent-amber: #f59e0b;
    --accent-ruby: #ef4444;
    --accent-indigo: #6366f1;

    /* Text */
    --text-primary: #f1f5f9;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;

    --font-heading: 'Outfit', 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

    --blur: blur(12px);
    --shadow-soft: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
    --shadow-glow: 0 0 20px rgba(6, 182, 212, 0.15);

    /* Animation Durations */
    --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-base: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

html,
body,
#root {
    height: 100%;
    background: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-heading);
    overflow-x: hidden;
}

/* ─── Modern Geometric Background ──────────────────────────────────────────────── */
.stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
        radial-gradient(circle at 20% 30%, rgba(99, 102, 241, 0.05) 0%, transparent 40%),
        radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.05) 0%, transparent 40%),
        linear-gradient(to bottom, transparent, var(--bg-dark) 80%);
}

.stars::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
        radial-gradient(1px 1px at 20px 30px, var(--text-muted) 1px, transparent 0),
        radial-gradient(1px 1px at 100px 150px, var(--text-muted) 1px, transparent 0);
    background-size: 150px 150px;
    opacity: 0.1;
}

/* ─── Typography & Effects ────────────────────────────────────────────────────────── */
h1,
h2,
h3 {
    font-weight: 700;
    letter-spacing: -0.025em;
}

.glow-text {
    text-shadow: 0 0 12px rgba(6, 182, 212, 0.4);
}

/* ─── Glass Cards ─────────────────────────────────────────────────────────────── */
.card {
    background: var(--bg-card);
    backdrop-filter: var(--blur);
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: var(--shadow-soft);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card:hover {
    border-color: var(--border-glow);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
}

.card h2 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

/* ─── Buttons ─────────────────────────────────────────────────────────────────── */
.btn-primary {
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-indigo));
    color: white;
    border: none;
    border-radius: 10px;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
}

.btn-primary:hover:not(:disabled) {
    transform: scale(1.02);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
}

.btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-ghost {
    background: rgba(148, 163, 184, 0.1);
    border: 1px solid rgba(148, 163, 184, 0.2);
    color: var(--text-secondary);
    border-radius: 10px;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-ghost:hover {
    background: rgba(148, 163, 184, 0.2);
    color: var(--text-primary);
}

/* ─── Header ────────────────────────────────────────────────────────────────── */
.header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(2, 6, 23, 0.8);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-light);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.header-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 800;
    background: linear-gradient(to right, var(--accent-cyan), var(--accent-indigo));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}

.logo-icon {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-indigo));
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1rem;
    -webkit-text-fill-color: initial;
}

/* ─── Dashboard Layout ────────────────────────────────────────────────────── */
.dashboard {
    min-height: 100vh;
    position: relative;
    display: flex;
    flex-direction: column;
}

.main-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 2rem;
    padding: 2rem;
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
}

.left-col,
.right-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

/* ─── Service Health ───────────────────────────────────────────────────────── */
.health-indicators {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
}

.health-dot {
    background: rgba(15, 23, 42, 0.4);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.2s;
}

.health-dot:hover {
    background: rgba(15, 23, 42, 0.6);
    border-color: var(--accent-cyan);
}

.dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    position: relative;
}

.dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    opacity: 0.4;
}

.up .dot {
    background: var(--accent-emerald);
}

.up .dot::after {
    background: var(--accent-emerald);
    box-shadow: 0 0 12px var(--accent-emerald);
}

.down .dot {
    background: var(--accent-ruby);
}

.down .dot::after {
    background: var(--accent-ruby);
    box-shadow: 0 0 12px var(--accent-ruby);
    animation: pulse-glow 1.5s infinite;
}

.checking .dot {
    background: var(--accent-amber);
}

.checking .dot::after {
    background: var(--accent-amber);
    animation: pulse-glow 1.5s infinite;
}

@keyframes pulse-glow {
    0% {
        transform: scale(1);
        opacity: 0.4;
    }

    50% {
        transform: scale(1.5);
        opacity: 0.1;
    }

    100% {
        transform: scale(1);
        opacity: 0.4;
    }
}

/* ─── Order Panel ──────────────────────────────────────────────────────────── */
.menu-item-card {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.6), rgba(15, 23, 42, 0.8));
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid var(--border-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.item-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.item-desc {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

/* ─── Stage Tracker ────────────────────────────────────────────────────────── */
.stage-track {
    display: flex;
    justify-content: space-between;
    margin: 3rem 0;
    position: relative;
}

.stage-track::before {
    content: '';
    position: absolute;
    top: 15px;
    left: 10%;
    right: 10%;
    height: 2px;
    background: var(--border-light);
    z-index: 0;
}

.stage {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    flex: 1;
}

.stage-dot {
    width: 32px;
    height: 32px;
    background: var(--bg-dark);
    border: 2px solid var(--border-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.stage.active .stage-dot {
    border-color: var(--accent-cyan);
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.4);
    background: var(--accent-cyan);
}

.stage.done .stage-dot {
    background: var(--accent-emerald);
    border-color: var(--accent-emerald);
}

.stage-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
}

.stage.active .stage-label {
    color: var(--accent-cyan);
}

.stage.done .stage-label {
    color: var(--accent-emerald);
}

/* ─── Metrics Grid ────────────────────────────────────────────────────────── */
.metrics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

.metric-block {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(15, 23, 42, 0.3);
    padding: 1.25rem;
    border-radius: 12px;
    border: 1px solid var(--border-light);
}

.metric-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
}

.metric-value {
    font-size: 1.25rem;
    font-weight: 700;
    font-family: var(--font-mono);
}

.metric-value.cyan {
    color: var(--accent-cyan);
}

.metric-value.emerald {
    color: var(--accent-emerald);
}

.metric-value.ruby {
    color: var(--accent-ruby);
}

/* ─── Toasts ────────────────────────────────────────────────────────────────── */
.toast-list {
    position: fixed;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    pointer-events: none;
}

.toast {
    pointer-events: auto;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-light);
    padding: 1rem 1.5rem;
    border-radius: 12px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
    margin-bottom: 0.5rem;
}

.toast-success {
    color: var(--accent-emerald);
    border-left: 4px solid var(--accent-emerald);
}

.toast-error {
    color: var(--accent-ruby);
    border-left: 4px solid var(--accent-ruby);
}

.toast-warning {
    color: var(--accent-amber);
    border-left: 4px solid var(--accent-amber);
}

/* ─── Chaos Panel ──────────────────────────────────────────────────────────── */
.chaos-buttons {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
}

.btn-chaos,
.btn-restore {
    padding: 1rem;
    border-radius: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-chaos {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    color: var(--accent-ruby);
}

.btn-restore {
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.2);
    color: var(--accent-emerald);
}

/* ─── Login Page ─────────────────────────────────────────────────────────────── */
.login-page {
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    background: radial-gradient(circle at center, #010409 0%, #000000 100%);
    overflow: hidden;
}

.login-card {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 440px;
    padding: 3.5rem;
    background: rgba(13, 17, 23, 0.7);
    backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 28px;
    box-shadow:
        0 25px 50px -12px rgba(0, 0, 0, 0.5),
        0 0 0 1px rgba(255, 255, 255, 0.03);
    animation: card-entrance 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes card-entrance {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.98);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.field {
    margin-bottom: 1.5rem;
}

.field label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
}

.field input {
    width: 100%;
    background: rgba(1, 1, 1, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    color: white;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.field input:focus {
    border-color: var(--accent-cyan);
    background: rgba(1, 1, 1, 0.5);
    box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.1);
}

.login-hint {
    margin-top: 2rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-muted);
}

.login-hint code {
    color: var(--accent-cyan);
    font-weight: 600;
}

.status-glow.checking {
    background: var(--amber);
    box-shadow: 0 0 10px var(--amber);
    animation: pulse-dot 1.5s ease-in-out infinite;
}

.admin-metric {
    font-size: 0.8rem;
    color: var(--muted);
}

.admin-metric span {
    color: var(--amber);
    font-weight: 600;
}

.admin-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
}

.btn-admin-action {
    flex: 1;
    padding: 0.4rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.2s;
}

.btn-admin-action:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

.btn-admin-action.slow {
    background: rgba(239, 68, 68, 0.15);
    color: var(--red);
    border-color: var(--red);
}

.btn-admin-action.slow:hover:not(:disabled) {
    background: rgba(239, 68, 68, 0.25);
}

.btn-admin-action.restore {
    background: rgba(16, 185, 129, 0.15);
    color: var(--green);
    border-color: var(--green);
}

.btn-admin-action.restore:hover:not(:disabled) {
    background: rgba(16, 185, 129, 0.25);
}

/* ─── Responsive ───────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
    .main-layout {
        grid-template-columns: 1fr;
        padding: 1rem;
    }

    .metrics-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .header {
        padding: 0.75rem 1rem;
    }
}

/* ─── Developer Protocol ───────────────────────────────────────────────────── */
.dev-protocol {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: rgba(15, 23, 42, 0.4);
    border: 1px dashed var(--border-light);
    border-radius: 12px;
    animation: fadeIn 0.5s ease;
}

.dev-protocol h3 {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.dev-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.dev-link-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    transition: var(--transition-base);
}

.dev-link-btn:hover {
    border-color: var(--accent-cyan);
    color: var(--text-primary);
    background: rgba(6, 182, 212, 0.05);
    transform: translateX(6px);
}

.dev-hint {
    font-size: 0.65rem;
    color: var(--text-muted);
    margin-top: 1rem;
    font-style: italic;
    opacity: 0.8;
}

/* ─── Resilience Terminal ───────────────────────────────────────────────────── */
.terminal {
    background: #000;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    max-height: 180px;
    overflow-y: auto;
    color: var(--accent-emerald);
}

.terminal-line {
    margin-bottom: 0.25rem;
    display: flex;
    gap: 0.5rem;
    opacity: 0;
    animation: slideUp 0.3s forwards;
}

.terminal-ts {
    color: var(--text-muted);
    min-width: 65px;
}

.terminal-tag {
    padding: 0 4px;
    border-radius: 2px;
    background: var(--accent-emerald);
    color: #000;
    font-weight: bold;
}

.terminal-tag.err {
    background: var(--accent-ruby);
}

.terminal-tag.info {
    background: var(--accent-cyan);
}

@keyframes slideUp {
    from {
        transform: translateY(10px);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

/* ─── Topo Diagram ───────────────────────────────────────────────────────── */
.topo-grid {
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 1.5rem 0;
    position: relative;
    margin-bottom: 1rem;
}

.topo-node {
    width: 60px;
    height: 60px;
    background: var(--bg-surface);
    border: 2px solid var(--border-light);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    z-index: 2;
    transition: all 0.5s;
}

.topo-node.active {
    border-color: var(--accent-cyan);
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
}

.topo-line {
    position: absolute;
    height: 2px;
    background: var(--border-light);
    z-index: 1;
    width: 30%;
}

.topo-line.l1 {
    left: 20%;
}

.topo-line.l2 {
    right: 20%;
}

.topo-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent, var(--accent-cyan), transparent);
    background-size: 200% 100%;
    animation: flow 2s linear infinite;
}

.success-pulse {
    animation: success-glow 2s infinite !important;
    background: var(--accent-emerald) !important;
}

@keyframes success-glow {
    0% {
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    }

    70% {
        box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
    }

    100% {
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
    }
}

@keyframes flow {
    from {
        background-position: 200% 0;
    }

    to {
        background-position: -200% 0;
    }
}
